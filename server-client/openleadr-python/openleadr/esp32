// Relay type: ACTIVE_LOW = relay triggers with LOW (common for ESP8266 relay modules)
const bool RELAY_ACTIVE_LOW = true;

// Helper to get physical pin state for a desired logical state
int getPinState(bool logicalState) {
  return RELAY_ACTIVE_LOW ? (logicalState ? LOW : HIGH) : (logicalState ? HIGH : LOW);
}

// Helper to get logical state from physical pin state
bool getLogicalState(int pinState) {
  return RELAY_ACTIVE_LOW ? (pinState == LOW) : (pinState == HIGH);
}

// ============================================================================
// RELAYS - Grouped as: Fans (1&2), Lights (3&4), AC (5)
// ============================================================================
const int NUM_RELAYS = 5;
const int relayPins[NUM_RELAYS] = {D1, D2, D6, D0, D5};

// Relay configuration
struct RelayGroup {
  int groupId;
  String name;
  int firstRelay;
  int lastRelay;
  int power_w;
  int priority;
};

RelayGroup groups[] = {
  {1, "Fans",   0, 1, 150, 7},   // Relay 1 & 2 (0-index: 0,1)
  {2, "Lights", 2, 3, 100, 6},   // Relay 3 & 4 (0-index: 2,3)
  {3, "AC",     4, 4, 1500, 9}   // Relay 5 (0-index: 4)
};

const int NUM_GROUPS = sizeof(groups) / sizeof(groups[0]);

// ============================================================================
// MQTT TOPICS
// ============================================================================
const char* controlTopic = "rl/relay/control";
const char* statusTopic  = "rl/relay/status";
const char* debugTopic   = "rl/relay/debug";
const char* registerTopic = "rl/relay/register";

// ============================================================================
// COMMAND QUEUE
// ============================================================================
struct PendingCmd {
  int groupIndex;
  bool state;
};

const int QUEUE_SIZE = 8;
PendingCmd cmdQueue[QUEUE_SIZE];
int qHead = 0;
int qTail = 0;

bool queueEmpty() { return qHead == qTail; }
bool queueFull() { return ((qTail + 1) % QUEUE_SIZE) == qHead; }

void enqueueCmd(int groupIndex, bool state) {
  if (!queueFull()) {
    cmdQueue[qTail].groupIndex = groupIndex;
    cmdQueue[qTail].state = state;
    qTail = (qTail + 1) % QUEUE_SIZE;
    Serial.printf("📦 Queued: Group %d -> %s\n", groupIndex + 1, state ? "ON" : "OFF");
  }
}

bool dequeueCmd(PendingCmd &out) {
  if (queueEmpty()) return false;
  out.groupIndex = cmdQueue[qHead].groupIndex;
  out.state = cmdQueue[qHead].state;
  qHead = (qHead + 1) % QUEUE_SIZE;
  return true;
}

